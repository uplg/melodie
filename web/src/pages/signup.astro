---
import Layout from '../layouts/Layout.astro';
import Wordmark from '../components/Wordmark.astro';
import { fetchMe } from '../lib/api';

const me = await fetchMe(Astro.request);
if (me) return Astro.redirect('/app');

// Allow `/signup?invite=CODE` to prefill the field.
const url = new URL(Astro.request.url);
const prefillInvite = url.searchParams.get('invite') ?? '';
---

<Layout title="Sign up — Melodie">
  <main class="mx-auto flex min-h-screen max-w-md flex-col justify-center px-6 py-16">
    <header class="mb-10 text-center">
      <Wordmark size="lg" />
    </header>

    <h1 class="text-2xl font-semibold tracking-tight">Sign up</h1>
    <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">
      Invite-only. Ask the operator for a code.
    </p>

    <form id="signup-form" class="mt-8 space-y-4" novalidate>
      <label class="block">
        <span class="text-sm font-medium">Invite code</span>
        <input
          name="invite_code"
          type="text"
          required
          value={prefillInvite}
          class="mt-1 w-full rounded-md border border-neutral-300 dark:border-neutral-700 bg-white dark:bg-neutral-900 px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-neutral-400"
        />
      </label>
      <label class="block">
        <span class="text-sm font-medium">Display name</span>
        <input
          name="display_name"
          type="text"
          required
          minlength="1"
          maxlength="64"
          autocomplete="nickname"
          class="mt-1 w-full rounded-md border border-neutral-300 dark:border-neutral-700 bg-white dark:bg-neutral-900 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-neutral-400"
        />
      </label>
      <label class="block">
        <span class="text-sm font-medium">Email</span>
        <input
          name="email"
          type="email"
          required
          autocomplete="email"
          class="mt-1 w-full rounded-md border border-neutral-300 dark:border-neutral-700 bg-white dark:bg-neutral-900 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-neutral-400"
        />
      </label>
      <label class="block">
        <span class="text-sm font-medium">Password</span>
        <input
          name="password"
          type="password"
          required
          minlength="8"
          autocomplete="new-password"
          class="mt-1 w-full rounded-md border border-neutral-300 dark:border-neutral-700 bg-white dark:bg-neutral-900 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-neutral-400"
        />
        <span class="mt-1 block text-xs text-neutral-500">8 characters minimum.</span>
      </label>

      <p
        id="signup-error"
        class="hidden text-sm text-red-600 dark:text-red-400"
        role="alert"
      ></p>

      <button
        type="submit"
        class="w-full rounded-md bg-neutral-900 dark:bg-neutral-100 text-white dark:text-neutral-900 px-3 py-2 text-sm font-medium hover:opacity-90 disabled:opacity-50"
      >
        Create account
      </button>
    </form>

    <p class="mt-6 text-sm text-neutral-600 dark:text-neutral-400">
      Already have an account? <a class="underline" href="/login">Sign in</a>.
    </p>
  </main>

  <script is:inline>
    const form = document.getElementById('signup-form');
    const errEl = document.getElementById('signup-error');
    const button = form.querySelector('button[type="submit"]');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errEl.classList.add('hidden');
      button.disabled = true;
      try {
        const data = Object.fromEntries(new FormData(form));
        const res = await fetch('/api/auth/signup', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (res.ok) {
          window.location.href = '/app';
          return;
        }
        const body = await res.json().catch(() => ({}));
        errEl.textContent = body?.error?.message ?? `Sign-up failed (${res.status})`;
        errEl.classList.remove('hidden');
      } catch (err) {
        errEl.textContent = 'Network error — try again.';
        errEl.classList.remove('hidden');
      } finally {
        button.disabled = false;
      }
    });
  </script>
</Layout>
