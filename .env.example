# --- Server ---
MELODIE_BIND=127.0.0.1:8080
MELODIE_DATABASE_URL=sqlite://./data/melodie.db?mode=rwc
MELODIE_SESSION_KEY=change-me-64-bytes-of-base64-please
MELODIE_PUBLIC_BASE_URL=http://localhost:4321

# --- Suno upstream (single shared identity) ---
# Either paste a Clerk cookie here for first boot, or use POST /api/admin/suno-auth later.
SUNO_CLERK_COOKIE=
# Encryption key for storing the cookie at rest in SQLite (32 bytes base64).
SUNO_COOKIE_KEY=

# --- Telegram alerts (admin only) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Logging ---
RUST_LOG=info,melodie_api=debug,suno_client=debug
