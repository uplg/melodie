# --- Server ---
MELODIE_BIND=127.0.0.1:8080
# MELODIE_LOCAL_URL=http://127.0.0.1:8080   # override if homie can't reach the bind port directly
MELODIE_DATABASE_URL=sqlite://./data/melodie.db?mode=rwc
# MELODIE_BOOTSTRAP_INVITE=
# MELODIE_COOKIE_SECURE=1   # set behind TLS (nginx, cloudflared)

# --- HeartMuLa engine (local checkpoints) ---
# `just fetch-models` downloads everything to these paths (see README "Models").
# Already have the checkpoints elsewhere (e.g. heartlib-mlx's ckpt/)? Point these there.
MELODIE_LM_DIR=data/models/HeartMuLa-oss-3B
MELODIE_CODEC_DIR=data/models/HeartCodec-oss
MELODIE_TOKENIZER=data/models/tokenizer.json
MELODIE_AUDIO_DIR=data/audio

# --- Homie push bridge (optional) ---
# HOMIE_PUSH_URL=http://127.0.0.1:7878/push
# HOMIE_PUSH_TOKEN=

# --- Logging ---
RUST_LOG=info,melodie_api=debug
